# DUMPS DE BASE DE DATOS (NO versionar - pueden contener datos reales)
#######################################
*.sql
dump-*.sql
*.dump

# EXCEPCIÓN: las migraciones/seeds/rollback de Coaching SÍ se versionan
# (son código de estructura, no datos — mismo criterio que ya tenías
# implícito para el resto del proyecto)
!database/migrations/*.sql
!database/seeds/*.sql
!database/rollback/*.sql